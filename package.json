{
  "name": "inkos",
  "version": "0.3.5",
  "private": true,
  "description": "Multi-agent novel production system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Narcooo/inkos"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "release": "pnpm build && pnpm test && pnpm -r --filter './packages/*' publish --no-git-checks"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
